  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 26
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 6
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: 'Senior Dev: Oh, it looks like this PC is encrypted, but the virus has
    left a file around!

    

    

    ROT13? That''s a substitution cypher
    in which the letters are shifted in a direction by 13 characters!

    Take
    ''A'' for example, in the alphabet it is the first letter! If we add 13 to it
    we will arrive at the 14 position, which is ''N''! But if we add 13 again to
    ''N'', we will arrive back at ''A''.

    

    

    To decrypt your files,
    you will have to first decrypt the password!

'
