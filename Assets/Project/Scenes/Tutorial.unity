  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 29
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 50
    m_Alignment: 6
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: 'Senior Dev: Yo, what''s up?



    You: Man, I just messed up I clicked
    on this link on my email and now everything went haywire at the workplace!



    Senior
    Dev: Can you send me the email?



    You: "Email.txt sent"



    Senior Dev:
    Classic phishing email..



    You: And what can I do? My computer has a red
    screen saying "You''ve been hacked".



    Senior Dev: It''s a notorious virus
    created to test the knowledge of people about cyber security! Fortunately it
    does nothing that malicious... it just blocks the computers behind some Capture
    The Flag challenges.



    You: I don''t know what they are! And my boss is
    gonna fire me if I don''t get it sorted out by morning!



    Senior Dev: Don''t
    worry! I''ve dealt with them before. This virus is installed on every computer
    on the network, each representing a different set of challenges. Check them out
    for yourself, and open your phone when you are ready to learn more about the
    challenge!


    [PRESS "ESC" TO RETURN TO THE LOBBY]'
